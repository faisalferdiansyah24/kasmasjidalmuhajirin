rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.token.email == 'faisalferdiansyah69@gmail.com' && request.auth.token.email_verified == true;
    }

    function isManualAdmin(uid) {
      return uid is string && uid.size() >= 12; // Just a basic check for the mock UID
    }

    function isAdmin() {
      return isHardcodedAdmin() || (isSignedIn() && getUserRole() == 'admin') || (!isSignedIn() && request.resource != null && isManualAdmin(incoming().createdBy));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Validation Helpers ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'categoryId', 'categoryName', 'description', 'date', 'createdBy', 'createdAt'])
        && data.type in ['income', 'expense']
        && data.amount is number && data.amount > 0
        && data.categoryId is string
        && data.categoryName is string
        && data.description is string
        && data.date is string
        && (data.createdBy == request.auth.uid || isManualAdmin(data.createdBy))
        && data.createdAt == request.time;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'type'])
        && data.name is string && data.name.size() <= 100
        && data.type in ['income', 'expense'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role'])
        && data.uid == request.auth.uid
        && data.role in ['admin', 'viewer'];
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if (isAdmin() || (isSignedIn() && isOwner(userId))) && isValidUser(incoming());
    }

    match /transactions/{transactionId} {
      allow read: if true;
      
      allow create: if isAdmin() && isValidTransaction(incoming());
      
      allow update: if (isAdmin() || (request.auth != null && existing().createdBy == request.auth.uid)) 
        && isValidTransaction(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['type', 'amount', 'categoryId', 'categoryName', 'description', 'date', 'updatedAt'])
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && (incoming().createdBy == existing().createdBy || (request.auth == null && isManualAdmin(incoming().createdBy)));
        
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(incoming());
    }
  }
}
